[Unit]
Description=Measure once and save result to SQLite
Wants=network-online.target
After=network-online.target time-sync.target

[Service]
Type=oneshot
User=pi
WorkingDirectory=/home/pi/measure_app
EnvironmentFile=-/home/pi/measure_app/.env
ExecStart=/home/pi/measure_app/.venv/bin/python /home/pi/measure_app/main.py run
